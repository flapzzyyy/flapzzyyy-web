# Server
PORT=8080

# Supabase PostgreSQL
# Transaction pooler (port 6543) for the app connection pool
DATABASE_URL=postgres://user:password@host:6543/postgres
# Direct/session connection (port 5432) for migrations
DIRECT_DATABASE_URL=postgres://user:password@host:5432/postgres

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=change-me

# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
