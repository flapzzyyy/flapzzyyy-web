# Server
PORT=8080

# Supabase PostgreSQL
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Transaction pooler (port 6543)
DATABASE_URL=postgres://user:password@host:6543/postgres
# Direct/session connection (port 5432)
DIRECT_DATABASE_URL=postgres://user:password@host:5432/postgres

# Auth (run: openssl rand -base64 32)
JWT_SECRET=change-me

# Allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Contact endpoint rate limit (requests per minute per IP)
RATE_LIMIT_RPM=5
